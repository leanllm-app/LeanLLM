# --- LLM Provider ---
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# GEMINI_API_KEY=...

# --- LeanLLM Persistence ---
# Database connection string (enables the event pipeline)
# Postgres (recommended for production):
LEANLLM_DATABASE_URL=postgresql://leanllm:leanllm@localhost:15432/leanllm
# SQLite (zero-config, dev/tests):
# LEANLLM_DATABASE_URL=sqlite:///./events.db

# Auto-run pending migrations on startup (Postgres only)
# LEANLLM_AUTO_MIGRATE=true

# --- LeanLLM Tuning (optional) ---
# LEANLLM_ENABLE_PERSISTENCE=true
# LEANLLM_QUEUE_MAX_SIZE=10000
# LEANLLM_BATCH_SIZE=100
# LEANLLM_FLUSH_INTERVAL_MS=200

# --- Privacy ---
# Store prompt/response text in DB (default: false)
# LEANLLM_CAPTURE_CONTENT=false
